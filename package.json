{
  "name": "stronger",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:local": "lsof -ti:8081 | xargs kill -9 2>/dev/null; adb wait-for-device && adb reverse tcp:8081 tcp:8081 && REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1 EXPO_DEBUG=1 expo start --port 8081",
    "android": "expo start --android",
    "build:android": "npx eas-cli build --platform android --profile preview",
    "build:android:run": "npx eas-cli build:run -p android --latest",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "e2e": "maestro test .maestro",
    "e2e:smoke": "maestro test --include-tags no-backend .maestro",
    "e2e:seed": "node scripts/e2e-seed-user.mjs",
    "db:push": "supabase db push",
    "//sandcastle": "npx tsx .sandcastle/main.mts"
  },
